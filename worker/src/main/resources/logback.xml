<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{YYYY-MM-dd HH:mm:ss.SSS} [%thread] %X{call-id} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
    <logger name="dev.octogene.pooly" level="debug" />
    <logger name="okhttp3.internal.concurrent.TaskRunner" level="error" />
    <logger name="io.opentelemetry.javaagent" level="error" />
    <logger name="io.opentelemetry.exporter.logging.LoggingSpanExporter" level="error" />
</configuration>
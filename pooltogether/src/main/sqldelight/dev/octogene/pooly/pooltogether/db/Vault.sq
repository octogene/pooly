import dev.octogene.pooly.core.ChainNetwork;

CREATE TABLE Vault (
  address TEXT PRIMARY KEY NOT NULL,
  name TEXT NOT NULL,
  symbol TEXT NOT NULL,
  network TEXT AS ChainNetwork NOT NULL,

  FOREIGN KEY (network) REFERENCES NetworkState(name)
  );

insertVault:
INSERT OR IGNORE INTO Vault(address, name, symbol, network)
VALUES (?, ?, ?, ?);

getAllVaultsAdresses:
SELECT address, network FROM Vault;
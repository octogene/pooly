CREATE TABLE Draw (
    walletAddress TEXT NOT NULL,
    vaultAddress TEXT NOT NULL,
    amount TEXT NOT NULL,
    timestamp INTEGER NOT NULL DEFAULT (strftime('%s', 'now')),
    transactionHash TEXT NOT NULL,

    PRIMARY KEY (walletAddress, vaultAddress, transactionHash),
    FOREIGN KEY (walletAddress) REFERENCES Wallet(address),
    FOREIGN KEY (vaultAddress) REFERENCES Vault(address)
);

insertDraw:
INSERT OR IGNORE INTO Draw(walletAddress, vaultAddress, amount, transactionHash)
VALUES (?,?, ?, ?);

getDrawsByWallet:
SELECT * FROM Draw
WHERE walletAddress = ?
ORDER BY timestamp DESC;

getLatestDrawForWallet:
SELECT * FROM Draw
WHERE walletAddress = ?
ORDER BY timestamp DESC
LIMIT 1;

getLatestDrawForVault:
SELECT * FROM Draw
WHERE walletAddress = ? AND vaultAddress = ?
ORDER BY timestamp DESC
LIMIT 1;

getAllDraws:
SELECT
    Draw.walletAddress,
    Draw.vaultAddress,
    Draw.amount,
    Draw.timestamp,
    Draw.transactionHash,
    Vault.name,
    Vault.symbol,
    Vault.network
FROM Draw
INNER JOIN Vault ON Draw.vaultAddress = Vault.address
ORDER BY Draw.timestamp DESC;

getLatestDrawTimestamp:
SELECT timestamp FROM Draw
ORDER BY timestamp DESC
LIMIT 1;